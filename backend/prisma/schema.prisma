generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
  moduleFormat  = "cjs"
}

datasource db {
  provider = "postgresql"
}

model User { 
  id    String @id @default(uuid())
  username  String @unique
  name  String
  password String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
