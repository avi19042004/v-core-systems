generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
  moduleFormat  = "cjs"
}

datasource db {
  provider = "postgresql"
}

model User { 
  id String @id @default(uuid())
  username String @unique
  name String
  password String
  permissionGroupId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  permissionGroup PermissionGroup @relation(fields: [permissionGroupId], references: [id])
  itemsCreated ItemMaster[] @relation("ItemCreatedBy")
  ItemsUpdated ItemMaster[] @relation("ItemUpdateBy")
  hsnsCreated HSNMaster[] @relation("HsnCreatedBy")
  hsnsUpdated HSNMaster[] @relation("HsnUpdateBy")
}

model PermissionGroup {
  id String @id @default(uuid())
  name String @unique
  permissions Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users User[]
}

model ItemMaster {
  id String @id @default(uuid())
  itemName String @unique
  hsnCode String
  createdById String
  updatedById String

  hsnMaster HSNMaster @relation(fields: [hsnCode], references: [hsnCode])
  createdBy User @relation("ItemCreatedBy", fields: [createdById], references: [id])
  updateBy User @relation("ItemUpdateBy", fields: [updatedById], references: [id])
}

model HSNMaster {
  hsnCode          String   @id
  importGST        Float
  saleGST          Float
  localPurchaseGST Float
  createdAt        DateTime @default(now())
  createdById String
  updatedById String

  items ItemMaster[]
  createdBy User @relation("HsnCreatedBy", fields: [createdById], references: [id])
  updateBy User @relation("HsnUpdateBy", fields: [updatedById], references: [id])
}